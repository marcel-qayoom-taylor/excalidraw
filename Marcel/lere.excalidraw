      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Im finding that getting customer code from views and searches \nis flawed. For some reason doing it with the new method is losing users. \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
