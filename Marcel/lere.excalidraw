      "roundness": null,
      "seed": 630462749,
      "version": 748,
      "versionNonce": 182784381,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1750037464989,
      "link": null,
      "locked": false,
      "text": "wait new issue... i can't just fetch all the users who have signed up\nbecause I need to know which country they're from to filter accordingly\nmy first idea was to just grab all the new sign ups and then \ncast them to be the country group of the current tpfm job but that\nwon't work as they could have signed up in any country and i'm forcefully \nassigning them to one.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "wait new issue... i can't just fetch all the users who have signed up\nbecause I need to know which country they're from to filter accordingly\nmy first idea was to just grab all the new sign ups and then \ncast them to be the country group of the current tpfm job but that\nwon't work as they could have signed up in any country and i'm forcefully \nassigning them to one.",
      "autoResize": true,
      "lineHeight": 1.25
    },
