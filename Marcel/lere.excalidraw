    {
      "id": "qYl9ITZN2H5nkCCBEOON8",
      "type": "text",
      "x": 4864.49752259581,
      "y": 1921.3748634691085,
      "width": 1026.0133080101662,
      "height": 490,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
