    {
      "id": "CoeAOLF_US641rY10B0Ur",
      "type": "text",
      "x": 4739.873210570508,
      "y": 1219.1795307550553,
      "width": 762.9717407226562,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
