    {
      "id": "_MD97FFPSi7L2Giv6swmg",
      "type": "text",
      "x": 7901.137759018644,
      "y": 4950.98787786563,
      "width": 1295.927734375,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
